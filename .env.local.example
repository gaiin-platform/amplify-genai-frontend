NEXTAUTH_SECRET={createsomethingsecrethere}
NEXTAUTH_URL=http://localhost:3000 (Should be the same as the amplify-genai-frontend url)
COGNITO_CLIENT_ID={fill_me_in}
COGNITO_DOMAIN={fill_me_in}
COGNITO_CLIENT_ID={fill_me_in}
COGNITO_CLIENT_SECRET={fill_me_in}
COGNITO_ISSUER=https://cognito-idp.{your-region}.amazonaws.com/{your-cognito-pool}
CHAT_ENDPOINT={fill_me_in}
API_BASE_URL={fill_me_in}
MIXPANEL_TOKEN={fill_me_in}

# Canvas LMS Integration API endpoint (optional)
NEXT_PUBLIC_CANVAS_API_URL={fill_me_in}

# services listed here (comma separated) will run locally. Include service name, port, and stage (for example: memory:3015:dev,auth:3016:dev,)
NEXT_PUBLIC_LOCAL_SERVICES={service_name:port:stage}

# Launch / outage UX controls. NEXT_PUBLIC_ prefix exposes to the browser so the
# banner and input disablement respond without a server round-trip.
# Set to "true" to show the maintenance banner and disable chat input.
NEXT_PUBLIC_MAINTENANCE_MODE=false
# Set to "false" to restrict access to users in the Cognito `amplify-pilot`
# group (plus admins). Flip to "true" to open to the full campus.
NEXT_PUBLIC_FULL_LAUNCH=true
# Status page URL, linked from the maintenance banner.
NEXT_PUBLIC_STATUS_PAGE_URL=https://status.hfu-amplify.org
